interface Notificacion {
    void enviar(String mensaje);
}

class Email implements Notificacion {
    public void enviar(String mensaje) {
        System.out.println("Email enviado: " + mensaje);
    }
}

class SMS implements Notificacion {
    public void enviar(String mensaje) {
        System.out.println("SMS enviado: " + mensaje);
    }
}

class Push implements Notificacion {
    public void enviar(String mensaje) {
        System.out.println("Push enviado: " + mensaje);
    }
}

public class MainNotificaciones {
    public static void main(String[] args) {
        Notificacion n1 = new Email();
        Notificacion n2 = new SMS();
        Notificacion n3 = new Push();

        n1.enviar("Hola!");
        n2.enviar("Mensaje importante");
        n3.enviar("Notificación push");
    }
} 
